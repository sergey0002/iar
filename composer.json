{
    "name": "noffprod/iar",
    "description": "Modern PHP Image Resizer",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "ext-gd": "*",
        "intervention/image": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "intervention/image": true
        },
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}